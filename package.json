{
	"name": "terminal.svelte",
	"version": "0.1.0",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ashwin-mahadevan/terminal.svelte.git"
	},
	"author": {
		"name": "Ashwin Mahadevan",
		"email": "mahadevan@ashwinm.com",
		"url": "https://ashwinm.com/"
	},
	"description": "Streaming terminal emulator component written in Svelte 5",
	"homepage": "https://github.com/ashwin-mahadevan/terminal.svelte",
	"bugs": {
		"url": "https://github.com/ashwin-mahadevan/terminal.svelte/issues"
	},
	"scripts": {
		"prepare": "svelte-kit sync",
		"prepack": "pnpm exec svelte-kit sync && pnpm exec svelte-package && pnpm exec publint"
	},
	"files": [
		"dist",
		"!dist/**/*.unit.js",
		"!dist/**/*.unit.d.ts",
		"!dist/**/*.dom.js",
		"!dist/**/*.dom.d.ts"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"@xterm/headless": "^6.0.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"node-gyp": "^12.3.0",
		"node-pty": "^1.1.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"socket.io": "^4.8.3",
		"socket.io-client": "^4.8.3",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"keywords": [
		"terminal",
		"emulator",
		"streaming",
		"svelte"
	]
}
